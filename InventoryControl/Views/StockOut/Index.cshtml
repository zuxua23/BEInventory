<body class="hold-transition sidebar-mini layout-fixed">

    <div class="wrapper">

        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")
        @Html.Partial("_Views")

        <div class="content-wrapper">

            <section class="content-header">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between flex-wrap mb-4">

                        <div class="d-flex align-items-center">
                            <div class="header-icon mr-3">
                                <i class="fas fa-dolly-flatbed nav-icon text-primary"
                                   style="font-size: 2.25rem; opacity: 0.8;"></i>
                            </div>
                            <div>
                                <h1 class="h3 mb-1 text-dark font-weight-bold">Stock Out</h1>
                                <p class="mb-0 text-muted small">Manage stock out process</p>
                            </div>
                        </div>

                        <nav aria-label="breadcrumb" class="modern-breadcrumb">
                            <ol class="breadcrumb bg-transparent p-0 mb-0">
                                <li class="breadcrumb-item">
                                    <a href="/dashboard" class="text-muted">
                                        <i class="fas fa-home mr-1"></i>Dashboard
                                    </a>
                                </li>
                                <li class="breadcrumb-item active">
                                    <i class="fas fa-clipboard-list mr-1"></i>Stock Out
                                </li>
                            </ol>
                        </nav>

                    </div>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">

                    <div class="row mb-4">

                        <div class="col-md-8">
                            <div class="card card-primary card-outline shadow-lg h-100">

                                <div class="card-header bg-white border-0 pb-0">
                                    <h5 class="font-weight-bold mb-0">
                                        <i class="fas fa-file-invoice mr-2 text-primary"></i>
                                        DO Information
                                    </h5>
                                </div>

                                <div class="card-body pt-3">

                                    <div class="form-group">
                                        <label class="font-weight-semibold">DO Number *</label>
                                        <select id="doIdSelect" class="form-control select2"></select>
                                    </div>

                                    <div class="form-group mb-0">
                                        <label class="font-weight-semibold">Reader *</label>
                                        <select id="rdrIdSelect" class="form-control select2"></select>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card shadow-lg h-100">

                                <div class="card-header bg-success text-white">
                                    <h6 class="mb-0">
                                        <i class="fas fa-info-circle mr-2"></i>Status
                                    </h6>
                                </div>

                                <div class="card-body text-center">

                                    <div id="processStatus"
                                         class="badge badge-secondary p-2 mb-3"
                                         style="font-size: 1rem;">
                                        Ready to Start
                                    </div>

                                    <div class="progress mb-2" style="height: 10px;">
                                        <div id="scanProgress"
                                             class="progress-bar bg-success"
                                             style="width: 0%">
                                        </div>
                                    </div>

                                    <small id="progressText" class="text-muted">
                                        0 / 0 scanned
                                    </small>

                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="card card-primary card-outline shadow-lg mb-4">

                        <div class="card-header bg-white border-0 pb-0">
                            <h5 class="font-weight-bold mb-0">
                                <i class="fas fa-list mr-2 text-primary"></i>
                                Item List
                            </h5>
                            <small class="text-muted">
                                Required vs Reserved vs Scanned
                            </small>
                        </div>
                        <div class="card-body pt-3">

                            <div class="table-responsive">
                                <table id="datatablesIndex" class="table table-hover">

                                    <thead class="thead-light">
                                        <tr>
                                            <th>Item Code</th>
                                            <th>Item Name</th>
                                            <th width="120">Required</th>
                                            <th width="120">Reserved</th>
                                            <th width="120">Scanned</th>
                                            <th width="150">Progress</th>
                                        </tr>
                                    </thead>

                                    <tbody id="itemList">
                                        <tr>
                                            <td colspan="6" class="text-center text-muted py-5">
                                                <i class="fas fa-box-open fa-2x mb-2"></i><br>
                                                Select DO to load items
                                            </td>
                                        </tr>
                                    </tbody>

                                </table>
                            </div>
                            </div>
                    </div>

                    <div class="row">

                        <div class="col-md-8">
                            <div class="card card-primary card-outline shadow-lg h-100">

                                <div class="card-header bg-white border-0 pb-0">
                                    <h5 class="font-weight-bold mb-0">
                                        <i class="fas fa-tags mr-2 text-primary"></i>
                                        Scanned Tags
                                    </h5>
                                </div>

                                <div class="card-body pt-3">
                                    <div id="tagList"
                                         style="max-height: 400px; overflow-y: auto;">

                                        <div class="text-center text-muted py-5">
                                            <i class="fas fa-qrcode fa-3x mb-3 opacity-50"></i>
                                            <p>Start scanning to see tags</p>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card shadow-lg h-100">

                                <div class="card-header bg-warning text-dark">
                                    <h6 class="mb-0">
                                        <i class="fas fa-qrcode mr-2"></i>RFID Scanner
                                    </h6>
                                </div>

                                <div class="card-body d-flex flex-column justify-content-center text-center">

                                    <button id="startScanBtn"
                                            class="btn btn-warning btn-block mb-3"
                                            onclick="startScanning()">
                                        <i class="fas fa-play mr-2"></i>Start Scan
                                    </button>

                                    <button class="btn btn-danger btn-block"
                                            onclick="stopScan()">
                                        <i class="fas fa-stop mr-2"></i>Stop Scan
                                    </button>

                                </div>
                            </div>
                        </div>

                    </div>

                </div>
            </section>


        </div>

        @Html.Partial("_Footer")

    </div>

  
    @Html.Partial("_BaseScript")

    <script src="~/helper/api.js"></script>
    <script src="~/helper/alert.js"></script>
    <script src="~/helper/table.js"></script>

    <script>

        let pollingInterval = null;
        let currentDo = null;

        $(document).ready(function () {
            loadDODropdown();
            loadReaderDropdown();
        });

        async function loadDODropdown() {

            const data = await Api.get("/api/pickinglist");
            if (!data) return Alert.error("Failed to load DO data");

            let options = `<option value="">-- Select DO --</option>`;

            data.forEach(d => {
                options += `<option value="${d.doId}">${d.doNumber}</option>`;
            });

            $("#doIdSelect").html(options);
            initSelect2();
        }

        async function loadReaderDropdown() {

            const data = await Api.get("/api/reader");
            if (!data) return Alert.error("Failed to load Reader data");

            let options = `<option value="">-- Select Reader --</option>`;

            data.forEach(r => {
                options += `
                    <option value="${r.id}" data-ip="${r.ipAddress}">
                        ${r.rdrName}
                    </option>`;
            });

            $("#rdrIdSelect").html(options);
            initSelect2();
        }

        function initSelect2() {
            $('#rdrIdSelect, #doIdSelect').select2({
                theme: 'bootstrap4',
                placeholder: "Search...",
                width: '100%',
                dropdownParent: $('body')
            });
        }

        $(document).on('select2:open', () => {
            document.querySelector('.select2-container--open .select2-search__field').focus();
        });

        async function startScanning() {

            const doId = $("#doIdSelect").val();
            const readerSelect = document.getElementById("rdrIdSelect");

            const readerId = readerSelect.value;
            const ip = readerSelect.options[readerSelect.selectedIndex]?.dataset.ip;

            if (!ip) return Alert.error("Reader IP not found");
            if (!doId || !readerId) return Alert.error("Select DO & Reader first");

            currentDo = doId;

            await Api.post("/stockout/start", {
                doId,
                readerId,
                ipAddress: ip
            });

            $("#processStatus")
                .text("Scanning...")
                .removeClass()
                .addClass("badge badge-warning");

            loadItems(doId);
            startPolling(doId);
        }

        async function stopScan() {

            const readerId = $("#rdrIdSelect").val();

            await Api.post(`/stockout/stop?readerId=${readerId}`);

            clearInterval(pollingInterval);

            $("#scanProgress").css("width", "0%");
            $("#progressText").text("0 / 0 scanned");

            $("#processStatus")
                .text("Ready")
                .removeClass()
                .addClass("badge badge-secondary");
        }

        function startPolling(doId) {

            if (pollingInterval) clearInterval(pollingInterval);

            pollingInterval = setInterval(async () => {
                try {

                    const items = await Api.get(`/stockout/items?doId=${doId}`);
                    if (!items) return;

                    updateItemProgress(items);
                    updateGlobalProgress(items);

                    await loadTags();

                } catch (err) {
                    console.error(err);
                }

            }, 1000);
        }

        function updateItemProgress(items) {

            items.forEach(item => {

                const row = document.querySelector(`[data-item="${item.itemId}"]`);
                if (!row) return;

                const percent = item.required
                    ? (item.scanned / item.required * 100)
                    : 0;

                if (item.scanned >= item.required) {
                    row.style.background = "#d4edda";
                }

                row.querySelector(".progress-bar").style.width = percent + "%";
                row.querySelector("small").textContent =
                    `${item.scanned}/${item.required}`;

                document.getElementById(`scan-${item.itemId}`).textContent =
                    item.scanned;
            });
        }

        function updateGlobalProgress(items) {

            const totalRequired = items.reduce((s, i) => s + i.required, 0);
            const totalScanned = items.reduce((s, i) => s + i.scanned, 0);

            const percent = totalRequired
                ? (totalScanned / totalRequired * 100)
                : 0;

            $("#scanProgress").css("width", percent + "%");
            $("#progressText").text(`${totalScanned} / ${totalRequired} scanned`);

            if (totalScanned === totalRequired && totalRequired > 0) {
                $("#processStatus")
                    .text("Completed")
                    .removeClass()
                    .addClass("badge badge-success");
            }
        }

        async function loadTags() {

            const tags = await Api.get(`/stockout/tags?doId=${currentDo}`);
            if (!tags) return;

            const tagList = $("#tagList");
            tagList.html("");

            tags.forEach(tag => {

                tagList.append(`
                    <div class="tag-item scanned">
                        <div class="tag-icon tag-scanned">✓</div>
                        <div>
                            <div class="font-weight-bold small">${tag.tagId}</div>
                            <div class="text-muted small">${tag.itemId}</div>
                        </div>
                    </div>
                `);
            });
        }

        async function loadItems(doId) {

            const items = await Api.get(`/stockout/items?doId=${doId}`);
            if (!items) return;

            const tbody = $("#itemList");
            tbody.html("");

            if (items.length === 0) {
                tbody.html(`
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No items available
                        </td>
                    </tr>
                `);
                return;
            }

            items.forEach(item => {

                const percent = item.required
                    ? (item.scanned / item.required * 100)
                    : 0;

                tbody.append(`
                    <tr data-item="${item.itemId}">
                        <td><strong>${item.itemCode}</strong></td>
                        <td>${item.itemName}</td>
                        <td><span class="badge badge-primary">${item.required}</span></td>
                        <td><span class="badge badge-warning">${item.reserved}</span></td>
                        <td>
                            <span class="badge badge-success" id="scan-${item.itemId}">
                                ${item.scanned}
                            </span>
                        </td>
                        <td>
                            <div class="progress">
                                <div class="progress-bar bg-info"
                                     style="width:${percent}%"></div>
                            </div>
                            <small>${item.scanned}/${item.required}</small>
                        </td>
                    </tr>
                `);
            });
        }

        $("#doIdSelect").on("change", function () {

            const doId = $(this).val();
            if (!doId) return;

            currentDo = doId;
            loadItems(doId);
        });

    </script>

</body>