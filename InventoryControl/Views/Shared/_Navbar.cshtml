<link rel="stylesheet" href="~/css/navbar.css" asp-append-version="true">

<nav class="main-header navbar navbar-light navbar-light-industrial">
    <ul class="navbar-nav">

        <li class="nav-item">

            <a class="nav-link"
               data-widget="pushmenu"
               href="#"
               role="button"
               title="Toggle Sidebar">

                <i class="fas fa-bars"></i>

            </a>

        </li>

    </ul>

    <ul class="navbar-nav ml-auto">
        <li class="nav-item mr-2"
            id="stockTakingWrapper"
            style="display:none;">
            <div id="stockTakingStatus"
                 class="stocktaking-indicator inactive d-flex align-items-center">
            </div>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-widget="fullscreen" href="#" role="button" title="Fullscreen">
                <i class="fas fa-expand-arrows-alt" style="font-size: 1.1rem;"></i>
            </a>
        </li>
    </ul>
</nav>
<script src="~/helper/api.js"></script>
<script src="~/helper/alert.js"></script>

<script>

    document.addEventListener("DOMContentLoaded", function () {

        loadStockTakingStatus();

        setInterval(loadStockTakingStatus, 10000);

    });

      async function loadStockTakingStatus() {

        try {

            const path = window.location.pathname
                .toLowerCase();

            if (path.includes("/stocktaking")) {
                return;
            }

            const data = await Api.get(
                "/api/stock-taking/active"
            );

            const wrapper = document.getElementById(
                "stockTakingWrapper"
            );

            const el = document.getElementById(
                "stockTakingStatus"
            );

            if (!wrapper || !el) return;

            if (data && data.status === "OPEN") {

                wrapper.style.display = "flex";

                el.classList.remove("inactive");
                el.classList.add("active");

                el.innerHTML = `
                    <i class="fas fa-circle"></i>
                    <span class="ml-1">
                        Stock Taking Active
                    </span>                
                `;

            } else {

                wrapper.style.display = "none";
            }

        } catch {

            const wrapper = document.getElementById(
                "stockTakingWrapper"
            );

            if (wrapper) {
                wrapper.style.display = "none";
            }
        }
    }

</script>