@using InventoryControl.Utility

@{
    var canUpdate = PermissionHelper.HasPermission(Context, "ITEM_UPDATE");
}
<body class="hold-transition sidebar-mini layout-fixed layout-navbar-fixed">

    <div class="wrapper">

        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")
        @Html.Partial("_Views")

        <div class="content-wrapper">

            <section class="content-header">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between flex-wrap mb-4">

                        <div class="d-flex align-items-center">
                            <div class="header-icon mr-3">
                                <i class="fas fa-boxes nav-icon text-primary" style="font-size: 2.25rem; opacity: 0.8;"></i>
                            </div>
                            <div>
                                <h1 class="h3 mb-1 text-dark font-weight-bold">Detail Item </h1>
                                <p class="mb-0 text-muted small">Manage your inventory items</p>
                            </div>
                        </div>

                        <nav aria-label="breadcrumb" class="modern-breadcrumb">
                            <ol class="breadcrumb bg-transparent p-0 mb-0">
                                <li class="breadcrumb-item">
                                    <a href="/dashboard" class="text-muted">
                                        <i class="fas fa-home mr-1"></i>Dashboard
                                    </a>
                                </li>
                                <li class="breadcrumb-item">
                                    <a href="/item" class="text-muted">
                                        <i class="fas fa-box mr-1"></i>Item
                                    </a>
                                </li>
                                <li class="breadcrumb-item active" aria-current="page">
                                    <i class="fas fa-box-open mr-1"></i>Detail Items
                                </li>
                            </ol>
                        </nav>

                    </div>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">
                    <div class="row justify-content-center">
                        <div class="col-12 ">
                            <div class="card form-card shadow-lg p-2 p-sm-3 p-md-4">
                                <div class="card-header">
                                    <h3 class="card-title mb-0 font-weight-bold">
                                        <i class="fas fa-edit mr-2 text-primary"></i>
                                        Edit Item Information
                                    </h3>
                                </div>
                                <div class="card-body">
                                    <form id="itemForm">
                                        <div class="form-group">
                                            <label>
                                                <i class="fas fa-hashtag text-muted mr-2"></i>
                                                Item ID
                                                <span class="badge badge-secondary ml-2">Auto-generated</span>
                                            </label>
                                            <input id="itemId" class="form-control" readonly>
                                        </div>

                                        <div class="form-group">
                                            <label>
                                                <i class="fas fa-tag text-muted mr-2"></i>
                                                Item Name <span class="text-danger">*</span>
                                            </label>
                                            <input id="itemName" name="itemName" class="form-control" @(canUpdate ? "" : "disabled")>
                                        </div>

                                    </form>

                                    <div class="d-flex justify-content-end pt-3 border-top">
                                        <a href="/item" class="btn btn-secondary btn-modern mr-3">
                                            <i class="fas fa-times mr-1"></i>Cancel
                                        </a>
                                        @if (canUpdate)
                                        {
                                            <button type="button" class="btn btn-primary btn-modern px-5" onclick="updateItem()">
                                                <i class="fas fa-save mr-2"></i>Update Item
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

        </div>

        @Html.Partial("_Footer")

    </div>

    @Html.Partial("_BaseScript")
    <script src="~/helper/api.js"></script>
    <script src="~/helper/alert.js"></script>

    <script>
        const canUpdate = @canUpdate.ToString().ToLower();
        let id = "@ViewData["id"]";

        $(document).ready(function () {
            loadItem();
        });

        async function loadItem() {

            const item = await Api.get(`/api/item/${id}`);

            if (!item) {
                Alert.error("Failed to load item");
                return;
            }

            $("#itemId").val(item.itemId);
            $("#itemName").val(item.itemName);
        }


        async function updateItem() {

            if (!canUpdate) {
                Alert.error("You do not have permission to update");
                return;
            }

            const payload = {
                itemName: $("#itemName").val()
            };

            const res = await Api.put(`/api/item/${id}`, payload);

            if (res && res.ok) {

                await Alert.success("Item updated successfully");

                window.location.href = "/item";
            }
        }


        $(document).keydown(function (e) {
            if (e.ctrlKey && e.key === 'Enter') updateItem();
            if (e.key === 'Escape') window.location.href = "/item";
        });

    </script>

</body>