@using InventoryControl.Utility

@{
    var canCreate = PermissionHelper.HasPermission(Context, "ITEM_CREATE");
    var canUpdate = PermissionHelper.HasPermission(Context, "ITEM_UPDATE");
    var canDelete = PermissionHelper.HasPermission(Context, "ITEM_DELETE");
}
<body class="hold-transition sidebar-mini layout-fixed">

    <div class="wrapper">


        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")
        @Html.Partial("_Views")

        <div class="content-wrapper">

            <section class="content-header">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between flex-wrap mb-4">

                        <div class="d-flex align-items-center">
                            <div class="header-icon mr-3">
                                <i class="fas fa-boxes nav-icon text-primary" style="font-size: 2.25rem; opacity: 0.8;"></i>
                            </div>
                            <div>
                                <h1 class="h3 mb-1 text-dark font-weight-bold">Item Management</h1>
                                <p class="mb-0 text-muted small">Manage your inventory items</p>
                            </div>
                        </div>

                        <nav aria-label="breadcrumb" class="modern-breadcrumb">
                            <ol class="breadcrumb bg-transparent p-0 mb-0">
                                <li class="breadcrumb-item">
                                    <a href="/dashboard" class="text-muted">
                                        <i class="fas fa-home mr-1"></i>Dashboard
                                    </a>
                                </li>
                                <li class="breadcrumb-item active" aria-current="page">
                                    <i class="fas fa-box mr-1"></i>Items
                                </li>
                            </ol>
                        </nav>

                    </div>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-12">
                            <!-- CARD MODERN -->
                            <div class="card card-primary card-outline shadow-lg">
                                <div class="card-header bg-white border-0 pb-0">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h3 class="card-title font-weight-bold mb-0">
                                            <i class="fas fa-list mr-2 text-primary"></i>
                                            Item List
                                        </h3>
                                        @if (canCreate)
                                        {
                                            <button class="btn btn-primary btn-icon-split" data-toggle="modal" data-target="#createItem">
                                                <span class="icon text-white-50">
                                                    <i class="fas fa-plus"></i>
                                                </span>
                                                <span class="text">Create</span>
                                            </button>
                                        }
                                    </div>
                                </div>

                                <div class="card-body pt-3">
                                    <!-- TABLE RESPONSIVE -->
                                    <div class="table-responsive">
                                        <table id="datatablesIndex" class="table table-hover ">
                                            <thead class="thead-light">
                                                <tr>
                                                    <th class="text-center" width="60">#</th>
                                                    <th class="text-nowrap">Item ID</th>
                                                    <th>Item Name</th>
                                                    @if (canUpdate || canDelete)
                                                    {
                                                        <th class="text-center" width="160">Actions</th>
                                                    }
                                                </tr>
                                            </thead>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

        </div>

        @Html.Partial("_Footer")

    </div>

    <div class="modal fade" id="createItem">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5>Create Item</h5>
                    <button class="close" data-dismiss="modal">&times;</button>
                </div>

                <form id="createItemForm">
                    <div class="modal-body">

                        <div class="form-group">
                            <label>Item ID</label>
                            <input type="text" id="itemId" name="itemId" class="form-control" readonly>
                        </div>

                        <div class="form-group">
                            <label>Item Name</label>
                            <input type="text" name="itemName" class="form-control" required>
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary">Create</button>
                    </div>
                </form>

            </div>
        </div>
    </div>

    @Html.Partial("_BaseScript")


    <script>
        const canUpdate = @canUpdate.ToString().ToLower();
        const canDelete = @canDelete.ToString().ToLower();


         function generateItemId(data) {

            let max = 0;

            data.forEach(item => {

                if (!item.itemId) return;

                let number = parseInt(item.itemId.replace("ITM", ""));

                if (number > max) {
                    max = number;
                }

            });

            let next = max + 1;

            let formatted = "ITM" + String(next).padStart(5, '0');

            $("#itemId").val(formatted);

        }

        let table;

        $(document).ready(function () {
            loadItems();
        });

        async function loadItems() {

            const response = await fetch("/api/item", {
                method: "GET",
                credentials: "include"
            });
            if (response.status === 401) {
            window.location.href = "/login";
            return;
        }

        if (response.status === 403) {
            alert("Tidak punya akses");
            return;
        }

            const data = await response.json();

            let showAction = canUpdate || canDelete;

            if ($.fn.DataTable.isDataTable('#datatablesIndex')) {
                $('#datatablesIndex').DataTable().clear().destroy();
            }

        table = $("#datatablesIndex").DataTable({
            data: data,

            responsive: true,
            pageLength: 5,
                    lengthMenu: [[5, 10, 25], [5, 10, 25]],

            columnDefs: [
                {
                    targets: 0,
                    data: null,
                    render: (data, type, row, meta) => meta.row + meta.settings._iDisplayStart + 1,
                    orderable: false,
                    searchable: false,
                    width: "5%",
                    className: "text-center"
                },
                {
                    targets: 1,
                    data: "itemId",
                    width: "18%",
                    orderable: true,
                    className: "text-nowrap"
                },
                {
                    targets: 2,
                    data: "itemName",
                    width: "55%",
                    responsivePriority: 1
                },
                {
                    targets: 3,
                    visible: showAction,
                    data: null,
                    render: data => {

                        let buttons = `<div class="btn-group btn-group-sm">`;

                        if (canUpdate) {
                            buttons += `
                                <a href="/item/detail?id=${data.id}" class="btn btn-info">
                                    <i class="fas fa-eye"></i>
                                </a>
                            `;
                        }

                        if (canDelete) {
                            buttons += `
                                <button class="btn btn-danger" onclick="deleteItem('${data.id}')" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            `;
                        }

                        buttons += `</div>`;

                        return buttons;
                    },
                    orderable: false,
                    width: "22%",
                    className: "text-center",
                    responsivePriority: 2
                }
            ],

            language: {
                search: "_INPUT_",
                searchPlaceholder: " Search items...",
                lengthMenu: "Show _MENU_ Items",
                paginate: { first: "«", last: "»", next: "›", previous: "‹" },
                info: "Showing _START_ to _END_ of _TOTAL_ items"
            },

            dom: "<'row mb-3'<'col-md-6'l><'col-md-6'f>>" +
                 "<'table-responsive card-body p-0't>" +
                 "<'row mt-3'<'col-md-5'i><'col-md-7'p>>",

            scrollCollapse: true,
            deferRender: true,

            autoWidth:false,
            fixedHeader:false,

            drawCallback: function() {
                $('.dataTables_length select').addClass('custom-select custom-select-sm rounded');
                $('.dataTables_filter input').addClass('form-control rounded shadow-sm');

                if($.fn.responsive){
                    table.responsive.recalc();
                }
            }
        });

        }

        $("#createItemForm").submit(async function (e) {
            e.preventDefault();

            const form = e.target;

            const payload = {
                itemName: form.itemName.value
            };

            const response = await fetch("/api/item", {
                method: "POST",
                credentials: "include",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            });


            if (response.ok) {
                Swal.fire({
                    icon: 'success',
                    title: 'Berhasil',
                    text: 'Item berhasil dibuat',
                    timer: 1500,
                    showConfirmButton: false
                }).then(() => {
                    $("#createItem").modal("hide");
                    loadItems();
                    form.reset();
                });
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Gagal',
                    text: 'Create item gagal'
                });

            }
        });

             async function deleteItem(id) {

            const result = await Swal.fire({
                title: 'Yakin?',
                text: "Item akan dihapus!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Ya, hapus!',
                cancelButtonText: 'Batal'
            });

            if (!result.isConfirmed) return;

            const response = await fetch(`/api/item/${id}`, {
                method: "DELETE",
                credentials: "include"
            });

            if (response.ok) {

                Swal.fire({
                    icon: 'success',
                    title: 'Berhasil',
                    text: 'Item berhasil dihapus',
                    timer: 1500,
                    showConfirmButton: false
                }).then(() => {
                    loadItems();
                });

            } else {

                Swal.fire({
                    icon: 'error',
                    title: 'Gagal',
                    text: 'Delete item gagal'
                });

            }
        }

         $('#createItem').on('shown.bs.modal', function () {

            const data = table.rows().data().toArray();

            generateItemId(data);

        });


        $(window).on('resize', function() {
            clearTimeout(window.datatableResizeTimeout);
            window.datatableResizeTimeout = setTimeout(function() {
                if (table) {
                    table.columns.adjust().responsive.recalc();
                }
            }, 250); // 250ms debounce
        });

        $(document).ready(function() {
            $(window).trigger('resize');
        });

        document.addEventListener('visibilitychange', function() {
            if (!document.hidden && table) {
                setTimeout(() => table.columns.adjust().responsive.recalc(), 100);
            }
        });
    </script>

</body>
