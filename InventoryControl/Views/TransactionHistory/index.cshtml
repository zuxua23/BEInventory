<body class="hold-transition sidebar-mini layout-fixed">

   

    <div class="wrapper">

        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")
        @Html.Partial("_Views")

       <div class="content-wrapper">

            <section class="content-header">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between flex-wrap mb-4">
                        <div class="d-flex align-items-center">
                            <div class="header-icon mr-3">
                                <i class="fas fa-history  nav-icon text-primary" style="font-size: 2.25rem; opacity: 0.8;"></i>
                            </div>
                            <div>
                                <h1 class="h3 mb-1 text-dark font-weight-bold">Transaction History</h1>
                                <p class="mb-0 text-muted small">Transaction History Overview</p>
                            </div>
                        </div>

                        <nav aria-label="breadcrumb" class="modern-breadcrumb">
                            <ol class="breadcrumb bg-transparent p-0 mb-0">
                                <li class="breadcrumb-item"><a href="/dashboard" class="text-muted"><i class="fas fa-home mr-1"></i>Dashboard</a></li>
                                <li class="breadcrumb-item active" aria-current="page"><i class="fas fa-box mr-1"></i>Transaction History</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-12">
                            
                            <div class="card card-primary card-outline shadow-lg card-tab">
                                <div class="card-header bg-white border-0 pb-0">

                                    <div class="custom-tab-menu modern-tabs">
                                        <button class="custom-tab-item active" data-value="">
                                            <i class="fas fa-layer-group mr-1"></i> All
                                        </button>
                                        <button class="custom-tab-item" data-value="STOCK_IN">
                                            <i class="fas fa-arrow-down mr-1"></i> Stock In
                                        </button>
                                        <button class="custom-tab-item" data-value="STOCK_PREPARATION">
                                            <i class="fas fa-box-open mr-1"></i> Preparation
                                        </button>
                                        <button class="custom-tab-item" data-value="STOCK_OUT">
                                            <i class="fas fa-arrow-up mr-1"></i> Stock Out
                                        </button>
                                    </div>
                                    <div class="card-title-wrapper d-flex justify-content-between align-items-center mt-3">
                                        <h3 class="card-title font-weight-bold mb-0">
                                            <i class="fas fa-filter mr-2 text-primary"></i>
                                            Filter Transactions
                                        </h3>
                                        <div class="d-flex justify-content-end mb-2">
                                            <div class="export-buttons-wrapper">
                                                <button id="btnExportExcel" class="btn export-btn export-excel" title="Export to Excel">
                                                    <i class="fas fa-file-excel mr-1"></i>
                                                    Excel
                                                </button>
                                                <button id="btnExportCsv" class="btn export-btn export-csv" title="Export to CSV">
                                                    <i class="fas fa-file-csv mr-1"></i>
                                                    CSV
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card-body pt-3">
                                    <div class="row filter-row mb-4">
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label class="text-muted small font-weight-bold">From Date</label>
                                                <input type="date" id="filterFromDate" class="form-control form-control-sm">
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label class="text-muted small font-weight-bold">To Date</label>
                                                <input type="date" id="filterToDate" class="form-control form-control-sm">
                                            </div>
                                        </div>
                                        <div class="col-md-4 d-flex align-items-end">
                                            <div class="w-100 d-flex">
                                                <button id="btnFilter" class="btn btn-primary btn-sm flex-fill mr-1" title="Filter Data">
                                                    <i class="fas fa-search"></i>
                                                </button>
                                                <button id="btnReset" class="btn btn-default btn-sm flex-fill" title="Reset Filter">
                                                    <i class="fas fa-sync-alt"></i>
                                                </button>
                                            </div>
                                        </div>

                                    </div>

                                    <hr>

                                    <div class="table-responsive">
                                        <table id="datatablesIndex" class="table table-hover">
                                            <thead class="thead-light">
                                                <tr>
                                                    <th class="text-center" width="60">#</th>
                                                    <th class="text-nowrap">Date</th>
                                                    <th>Transaction Type</th>
                                                    <th class="text-nowrap">DO Number</th>
                                                    <th>Reader Name</th>
                                                    <th>Tag Id</th>
                                                    <th>Item Name</th>
                                                    <th>Location Name</th>
                                                </tr>
                                            </thead>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

        </div>

        @Html.Partial("_Footer")

    </div>

    @Html.Partial("_BaseScript")

    <script>
            let table;
            let currentTxType = "";

            async function fetchTransactions(fromDate, toDate, txType) {

        const params = new URLSearchParams();

        if (fromDate) params.append("fromDate", fromDate);
        if (toDate) params.append("toDate", toDate);
        if (txType) params.append("txType", txType);

        const url = `/api/transaction/history?${params.toString()}`;

        const res = await fetch(url, {
            credentials: "include"
        });

                if (!res.ok) {
            Swal.fire("Error", "Failed to load transactions", "error");
            return [];
        }
                                if (res.status === 401) {
            window.location.href = "/login";
            return [];
        }

        if (res.status === 403) {
            Swal.fire("Access denied", "", "warning");
            return [];
        }
        return await res.json();
        }

            $(document).ready(function () {
                loadData();

                $(".custom-tab-item").on("click", function() {
                    $(".custom-tab-item").removeClass("active");
                    $(this).addClass("active");
                    
                    currentTxType = $(this).data("value");
                    
                    loadData();
                });

                $("#btnFilter").on("click", function() {
                    loadData();
                });

                $("#btnReset").on("click", function() {
                    $("#filterFromDate").val("");
                    $("#filterToDate").val("");
                    
                    $(".custom-tab-item").removeClass("active");
                    $(".custom-tab-item[data-value='']").addClass("active");
                    currentTxType = "";

                    loadData();
                });
            });

            async function loadData() {



                const fromDate = $("#filterFromDate").val();
                const toDate = $("#filterToDate").val();

                const data = await fetchTransactions(fromDate, toDate, currentTxType);

                if ($.fn.DataTable.isDataTable('#datatablesIndex')) {
                    $('#datatablesIndex').DataTable().clear().destroy();
                }

                table = $("#datatablesIndex").DataTable({
                    data: data,
                    responsive: true,
                    pageLength: 5,
                    lengthMenu: [[5, 10, 25], [5, 10, 25]],

                    autoWidth: false, 
                    columnDefs: [
                        { targets: 0, data: null, render: (data, type, row, meta) => meta.row + meta.settings._iDisplayStart + 1, orderable: false, searchable: false, width: "5%", className: "text-center" },
                        {
                            targets: 1,
                            data: "txDate",
                            width: "10%",
                            className: "text-nowrap",
                            render: function (data) {
                                if (!data) return "-";

                                return new Date(data).toLocaleDateString("id-ID");
                            }
                        },
                        {
                            targets: 2,
                            data: "txType",
                            width: "15%",
                            responsivePriority: 2, 
                            render: function (data) {
                                if (data === "STOCK_IN") return `<span class="badge badge-success">${data}</span>`;
                                if (data === "STOCK_PREPARATION") return `<span class="badge badge-warning">${data}</span>`;
                                if (data === "STOCK_OUT") return `<span class="badge badge-danger">${data}</span>`;
                                return data;
                            }
                        },
                        {
                            targets: 3,
                            data: "doNumber",
                            width: "15%",
                            className: "text-nowrap" 
                        },
                        { targets: 4, data: "readerName", render: data => data || "-", width: "15%" },
                        { targets: 5, data: "tagId", width: "15%", render: function(data) { return `<code>${data}</code>`; } },
                        {
                            targets: 6,
                            data: "itemName",
                            width: "15%",
                            responsivePriority: 1  
                        },
                        { targets: 7,
                            data: "locationName",
                            width: "15%",
                        }
                    ],
                    language: {
                        search: "_INPUT_",
                        searchPlaceholder: " Search transactions...",
                        lengthMenu: "Show _MENU_ Entries",
                        emptyTable: "No transactions found.",
                        paginate: { previous: "Previous", next: "Next" }
                    },
                    dom: "<'row mb-3'<'col-md-6'l><'col-md-6'f>>" +
                         "<'table-responsive card-body p-0't>" +
                         "<'row mt-3 align-items-center'<'col-md-5'i><'col-md-7'p>>",
                    drawCallback: function() {
                        $('.dataTables_length select').addClass('custom-select custom-select-sm rounded');
                        $('.dataTables_filter input').addClass('form-control form-control-sm rounded shadow-sm');
                        if($.fn.responsive){
                            table.responsive.recalc();
                        }
                    }
                });
            }
            $(window).on('resize', function() {
                clearTimeout(window.datatableResizeTimeout);
                window.datatableResizeTimeout = setTimeout(function() {
                    if (table) {
                        table.columns.adjust().responsive.recalc();
                    }
                }, 250);
            });

            $(document).ready(function() {
                $(window).trigger('resize');
            });

            document.addEventListener('visibilitychange', function() {
                if (!document.hidden && table) {
                    setTimeout(() => table.columns.adjust().responsive.recalc(), 100);
                }
            });


        function buildExportUrl(type) {
            const fromDate = $("#filterFromDate").val();
            const toDate = $("#filterToDate").val();

        const params = new URLSearchParams();

        if (fromDate) params.append("fromDate", fromDate);
        if (toDate) params.append("toDate", toDate);
        if (currentTxType) params.append("txType", currentTxType);

        return `/api/transaction/export/${type}?${params.toString()}`;
        }

        $("#btnExportExcel").on("click", function () {
            exportFile("excel");
        });

        $("#btnExportCsv").on("click", function () {
            exportFile("csv");
        });

        async function exportFile(type) {
            const url = buildExportUrl(type); 

            try {
                $("#btnExportExcel, #btnExportCsv").prop("disabled", true);

                Swal.fire({
                    title: "Exporting...",
                    text: "Please wait while file is being generated",
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });

                const response = await fetch(url, {
                    method: "GET",
                    credentials: "include"
                });

                if (!response.ok) throw new Error("Export failed");

                const blob = await response.blob();

                let fileName = "export";
                const disposition = response.headers.get("Content-Disposition");

                if (disposition) {
                    let fileNameMatch = disposition.match(/filename\*=UTF-8''([^;]+)/);

                    if (fileNameMatch && fileNameMatch[1]) {
                        fileName = decodeURIComponent(fileNameMatch[1]);
                    } else {
                        fileNameMatch = disposition.match(/filename="?([^"]+)"?/);
                        if (fileNameMatch && fileNameMatch[1]) {
                            fileName = fileNameMatch[1];
                        }
                    }
                }

                const urlBlob = window.URL.createObjectURL(blob);
                const a = document.createElement("a");
                a.href = urlBlob;
                a.download = fileName;
                document.body.appendChild(a);
                a.click();
                a.remove();

                window.URL.revokeObjectURL(urlBlob);

                Swal.fire({
                    icon: "success",
                    title: "Export Complete",
                    timer: 1500,
                    showConfirmButton: false
                });

            } catch (err) {
                Swal.fire({
                    icon: "error",
                    title: "Export Failed",
                    text: err.message
                });
            } finally {
                $("#btnExportExcel, #btnExportCsv").prop("disabled", false);
            }
        }
    </script>
</body>