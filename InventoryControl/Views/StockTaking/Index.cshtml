    <script>

        let currentSttId = null;
        let refreshInterval = null;

                $(".btn-success").on("click", async function () {
            const remark = $("input").val();
            const location = $("select").val();

            if (!location) {
                alert("Pilih lokasi dulu");
                return;
            }

            const res = await fetch("/api/stock-taking/create", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    remark: remark,
                    locationId: location
                })
            });

            const data = await res.json();

            currentSttId = data.sttId;

            loadStockTaking();

            // auto refresh tiap 3 detik 🔥
            if (refreshInterval) clearInterval(refreshInterval);
            refreshInterval = setInterval(loadStockTaking, 3000);
        });

                async function loadStockTaking() {
            if (!currentSttId) return;

            const res = await fetch(`/api/stock-taking/compare/${currentSttId}`);
            const data = await res.json();

            // RESET TABLE
            tableOriginal.clear();
            tableCollect.clear();

            let totalItems = 0;
            let totalStock = 0;
            let scanned = 0;

            data.forEach(x => {
                totalItems++;
                totalStock += x.qtySystem;

                if (x.qtyScan > 0) scanned++;

                // TABLE ORIGINAL
                tableOriginal.row.add([
                    x.itemId,
                    x.qtySystem,
                    "-"
                ]);

                // TABLE SCAN
        let row = tableCollect.row.add([
            x.itemId,
            x.qtyScan || "-",
            "-",
            x.status
        ]).node();

        if (x.selisih < 0) {
            $(row).addClass("table-danger");
        } else if (x.selisih > 0) {
            $(row).addClass("table-success");
        }
            });

            tableOriginal.draw();
            tableCollect.draw();

            // UPDATE HEADER
            $("#totalItems").text(totalItems);
            $("#totalStock").text(totalStock);

            $("#totalData").text(totalItems);
            $("#scannedCount").text(scanned);

            let percent = totalItems === 0 ? 0 : Math.round((scanned / totalItems) * 100);
            $("#progressPercent").text(percent + "%");
        }

                $("#endBtn").click(async function () {
            if (!currentSttId) return;

            if (!confirm("Yakin mau selesai?")) return;

            await fetch(`/api/stock-taking/finalize`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ sttId: currentSttId })
            });

            alert("Stock Taking selesai");
            clearInterval(refreshInterval);
        });

        let tableOriginal;
        let tableCollect;

        $(document).ready(function () {

            // INIT TABLE 1
        tableOriginal = $("#originalTable").DataTable({
            pageLength: 5,
            lengthMenu: [[5,10,25],[5,10,25]],

            language: {
                search: "_INPUT_",
                searchPlaceholder: "Search item...",
                lengthMenu: "Show _MENU_ Entries",
                emptyTable: "No data available",
                paginate: {
                    previous: "Previous",
                    next: "Next"
                }
            },

            dom: "<'row mb-2'<'col-md-6'l><'col-md-6'f>>" +
                 "t" +
                 "<'row mt-2'<'col-md-5'i><'col-md-7'p>>"
        });

            // INIT TABLE 2
        tableCollect = $("#collectTable").DataTable({
            pageLength: 5,
            lengthMenu: [[5,10,25],[5,10,25]],

            language: {
                search: "_INPUT_",
                searchPlaceholder: "Search data scanning...",
                lengthMenu: "Show _MENU_ Entries",
                emptyTable: "No data found.",
                paginate: {
                    previous: "Previous",
                    next: "Next"
                }
            },

            dom: "<'row mb-2'<'col-md-6'l><'col-md-6'f>>" +
                 "t" +
                 "<'row mt-2'<'col-md-5'i><'col-md-7'p>>",

            createdRow: function(row, data, dataIndex) {
                let status = data[3].toLowerCase();

                if (status.includes("scanned")) {
                    $(row).addClass("row-scanned");
                } else {
                    $(row).addClass("row-pending");
                }
            }
        });

            // SEARCH
            $("#searchOriginal").on("keyup", function () {
                tableOriginal.search(this.value).draw();
            });

            $("#searchCollect").on("keyup", function () {
                tableCollect.search(this.value).draw();
            });

            // FILTER STATUS
            $.fn.dataTable.ext.search.push(function(settings, data) {

                if (settings.nTable.id !== "collectTable") return true;

                let selected = $("#filterStatus").val().toLowerCase();
                let status = data[3].toLowerCase();

                if (!selected) return true;

                return status.includes(selected);
            });

            $("#filterStatus").on("change", function () {
                tableCollect.draw();
            });

        });
    </script>

