<body class="hold-transition sidebar-mini layout-fixed layout-navbar-fixed">

    <div class="wrapper">

        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")
        @Html.Partial("_Views")

        <div class="content-wrapper">

            <section class="content-header">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between flex-wrap mb-4">

                        <div class="d-flex align-items-center">
                            <div class="header-icon mr-3">
                                <i class="fas fa-user nav-icon text-primary"
                                   style="font-size: 2.25rem; opacity: 0.8;"></i>
                            </div>
                            <div>
                                <h1 class="h3 mb-1 text-dark font-weight-bold">Detail User</h1>
                                <p class="mb-0 text-muted small">Manage user information</p>
                            </div>
                        </div>

                        <nav class="modern-breadcrumb">
                            <ol class="breadcrumb bg-transparent p-0 mb-0">
                                <li class="breadcrumb-item">
                                    <a href="/home" class="text-muted">
                                        <i class="fas fa-home mr-1"></i>Dashboard
                                    </a>
                                </li>
                                <li class="breadcrumb-item">
                                    <a href="/user" class="text-muted">
                                        <i class="fas fa-users mr-1"></i>User
                                    </a>
                                </li>
                                <li class="breadcrumb-item active">
                                    <i class="fas fa-user mr-1"></i>Detail
                                </li>
                            </ol>
                        </nav>

                    </div>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">
                    <div class="row justify-content-center">
                        <div class="col-12">

                            <div class="card form-card shadow-lg p-2 p-sm-3 p-md-4">

                                <div class="card-header">
                                    <h3 class="card-title font-weight-bold mb-0">
                                        <i class="fas fa-edit mr-2 text-primary"></i>
                                        Edit User
                                    </h3>
                                </div>

                                <div class="card-body">

                                    <form>

                                        <div class="form-group">
                                            <label><i class="fas fa-hashtag mr-2"></i>User ID</label>
                                            <input id="userId" class="form-control" readonly>
                                        </div>

                                        <div class="form-group">
                                            <label><i class="fas fa-user mr-2"></i>Username</label>
                                            <input id="username" class="form-control">
                                        </div>

                                        <div class="form-group">
                                            <label><i class="fas fa-id-card mr-2"></i>Full Name</label>
                                            <input id="fullname" class="form-control">
                                        </div>

                                        <div class="form-group">
                                            <label><i class="fas fa-user-shield mr-2"></i>Role</label>
                                            <input id="RoleUpdate" class="form-control">
                                        </div>

                                    </form>

                                    <div class="d-flex justify-content-end pt-3 border-top">
                                        <a href="/user" class="btn btn-secondary btn-modern mr-3">
                                            <i class="fas fa-times mr-1"></i>Cancel
                                        </a>
                                        <button class="btn btn-warning btn-modern mr-2"
                                                data-toggle="modal"
                                                data-target="#updatePassword">
                                            <i class="fas fa-key mr-1"></i>Password
                                        </button>
                                        <button class="btn btn-info btn-modern mr-2"
                                                data-toggle="modal"
                                                data-target="#roleUpdate">
                                            <i class="fas fa-plus mr-1"></i>Role
                                        </button>
                                        <button class="btn btn-primary btn-modern px-5"
                                                onclick="updateUser()">
                                            <i class="fas fa-save mr-2"></i>Update
                                        </button>
                                    </div>

                                </div>

                            </div>

                        </div>
                    </div>
                </div>
            </section>

        </div>

        @Html.Partial("_Footer")

    </div>

    <div class="modal fade" id="updatePassword">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5>Update Password</h5>
                    <button class="close" data-dismiss="modal">&times;</button>
                </div>

                <div class="modal-body">
                    <div class="form-group">
                        <label><i class="fas fa-lock mr-2"></i>New Password</label>
                        <input type="password" id="newPassword" class="form-control">
                    </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-primary btn-modern" onclick="updatePassword()">
                        <i class="fas fa-save mr-1"></i>Update
                    </button>
                </div>

            </div>
        </div>
    </div>

    <div class="modal fade" id="roleUpdate">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5>Update Role User</h5>
                    <button class="close" data-dismiss="modal">&times;</button>
                </div>

                <form id="RoleUpdateForm">
                    <div class="modal-body">
                    
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-hashtag mr-2"></i>User ID</label>
                                    <input type="text" name="targetUserId" id="modalUserId" class="form-control" readonly>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label><i class="fas fa-user-shield mr-2"></i>Current Role</label>
                                    <input type="text" id="modalCurrentRole" class="form-control" readonly>
                                </div>
                            </div>
                        </div>

                        <hr> <label>Assign New Roles</label>
                        <div id="detailContainer">
                        </div>

                        <button type="button" class="btn btn-success btn-sm mt-2" onclick="addDetail()">
                            <i class="fas fa-plus mr-1"></i> Add Role
                        </button>
                    </div>

                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary btn-modern">
                            <i class="fas fa-save mr-1"></i>Update Roles
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @Html.Partial("_BaseScript")

    <script>

        let id = "@ViewData["id"]";

        $(document).ready(function(){
            loadUser();
        });

        async function loadUser(){

            const response=await fetch(`/api/user/${id}`,{
                method:"GET",
                credentials:"include"
            });

            const user=await response.json();

            $("#userId").val(user.userId);
            $("#username").val(user.username);
            $("#fullname").val(user.fullname);
        }

        async function updateUser(){

            const payload={
                id:id,
                userId:$("#userId").val(),
                username:$("#username").val(),
                fullname:$("#fullname").val()
            };

            const response=await fetch(`/api/user/${id}`,{
                method:"PUT",
                credentials:"include",
                headers:{ "Content-Type":"application/json" },
                body:JSON.stringify(payload)
            });

            if(response.ok){
                Swal.fire({
                    icon:"success",
                    title:"Berhasil",
                    timer:1500,
                    showConfirmButton:false
                });
            }else{
                Swal.fire({ icon:"error", title:"Gagal update" });
            }
        }

        async function updatePassword(){

            const payload={
                password:$("#newPassword").val()
            };

            const response=await fetch(`/api/user/${id}`,{
                method:"PUT",
                credentials:"include",
                headers:{ "Content-Type":"application/json" },
                body:JSON.stringify(payload)
            });

            if(response.ok){
                $("#updatePassword").modal("hide");
                Swal.fire({
                    icon:"success",
                    title:"Password updated",
                    timer:1500,
                    showConfirmButton:false
                });
            }else{
                Swal.fire({ icon:"error", title:"Gagal update password" });
            }
        }

        $(document).keydown(function(e){
            if(e.ctrlKey && e.key==='Enter') updateUser();
            if(e.key==='Escape') window.location.href="/user";
        });

                        // Script untuk mengisi User ID dan Current Role pas modal dibuka
            $('#roleUpdate').on('shown.bs.modal', function () {
                // Ambil value dari input di form utama
                $("#modalUserId").val($("#userId").val());
                $("#modalCurrentRole").val($("#RoleUpdate").val()); // Asumsi field "Role" di form utama id-nya RoleUpdate

                // Kalau kosong, otomatis kasih 1 baris input dropdown
                if ($("#detailContainer").is(':empty')) {
                    addDetail();
                }
            });

            // Fungsi untuk nambah baris dropdown (Select2 / bisa diketik)
            function addDetail() {
                const rowId = Date.now();
                const html = `
                    <div class="detail-item d-flex align-items-center mb-2" id="row_${rowId}">
                        <div class="flex-grow-1 mr-2">
                            <select class="form-control role-select" required style="width: 100%;">
                                <option value="">-- Select Role --</option>
                                <option value="Admin">Admin</option>
                                <option value="Warehouse">Warehouse</option>
                                <option value="Manager">Manager</option>
                                <option value="Staff">Staff</option>
                            </select>
                        </div>
                        <button type="button" class="btn btn-danger btn-sm" onclick="$('#row_${rowId}').remove()">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                `;

                $("#detailContainer").append(html);

                // Aktifin fitur select2 biar bisa diketik/search
                $(`#row_${rowId} .role-select`).select2({
                    theme: 'bootstrap4',
                    placeholder: "Search role...",
                    dropdownParent: $('#roleUpdate') // Biar dropdown nggak ketutup modal
                });
            }

            // Logic buat submit datanya
            $("#RoleUpdateForm").submit(async function (e) {
                e.preventDefault();

                let details = [];

                // Ambil semua role yang dipilih
                $("#detailContainer .detail-item").each(function () {
                    const selectedRole = $(this).find(".role-select").val();
                    if (selectedRole) {
                        details.push(selectedRole);
                    }
                });

                // Sesuaikan payload dengan kebutuhan API lo
                const payload = {
                    userId: $("#modalUserId").val(),
                    roles: details
                };

                const response = await fetch("/api/user/update-roles", { // Sesuaikan endpoint API-nya
                    method: "POST", // Atau PUT tergantung backend lo
                    credentials: "include",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                });

                if (response.ok) {
                    Swal.fire({
                        icon: "success",
                        title: "Berhasil",
                        text: "Role berhasil diupdate",
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => {
                        $("#roleUpdate").modal("hide");
                        $("#detailContainer").empty(); // Kosongin lagi
                        loadUser(); // Refresh data di layar utama
                    });
                } else {
                    Swal.fire({
                        icon: "error",
                        title: "Gagal",
                        text: "Gagal update role"
                    });
                }
            });
    </script>

</body>