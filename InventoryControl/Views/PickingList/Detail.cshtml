@using InventoryControl.Utility
@{
    var canUpdate = PermissionHelper.HasPermission(Context, "PICKINGLIST_UPDATE");
}

<body class="hold-transition sidebar-mini layout-fixed layout-navbar-fixed">

    <div class="wrapper">

        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")
        @Html.Partial("_Views")

        <div class="content-wrapper">

            <section class="content-header">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between flex-wrap mb-4">

                        <div class="d-flex align-items-center">
                            <div class="header-icon mr-3">
                                <i class="fas fa-clipboard-check nav-icon text-primary"
                                   style="font-size: 2.25rem; opacity: 0.8;"></i>
                            </div>
                            <div>
                                <h1 class="h3 mb-1 text-dark font-weight-bold">Detail Picking List</h1>
                                <p class="mb-0 text-muted small">Manage picking list data</p>
                            </div>
                        </div>

                        <nav aria-label="breadcrumb" class="modern-breadcrumb">
                            <ol class="breadcrumb bg-transparent p-0 mb-0">
                                <li class="breadcrumb-item">
                                    <a href="/dashboard" class="text-muted">
                                        <i class="fas fa-home mr-1"></i>Dashboard
                                    </a>
                                </li>
                                <li class="breadcrumb-item">
                                    <a href="/pickinglist" class="text-muted">
                                        <i class="fas fa-clipboard-list mr-1"></i>Picking List
                                    </a>
                                </li>
                                <li class="breadcrumb-item active">
                                    <i class="fas fa-clipboard-check mr-1"></i>Detail
                                </li>
                            </ol>
                        </nav>

                    </div>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">
                    <div class="row justify-content-center">
                        <div class="col-12">

                            <div class="card form-card shadow-lg p-2 p-sm-3 p-md-4">

                                <div class="card-header">
                                    <h3 class="card-title mb-0 font-weight-bold">
                                        <i class="fas fa-edit mr-2 text-primary"></i>
                                        Edit Picking List
                                    </h3>
                                </div>

                                <div class="card-body">

                                    <form id="pickingForm">

                                        <div class="form-group">
                                            <label>
                                                <i class="fas fa-barcode text-muted mr-2"></i>
                                                DO Number
                                            </label>
                                            <input id="doNumber" class="form-control" readonly>
                                        </div>


                                        <div id="details"></div>

                                        <button type="button"
                                                class="btn btn-success btn-sm mt-2"
                                                onclick="addDetail()">
                                            <i class="fas fa-plus mr-1"></i>Item
                                        </button>

                                    </form>

                                    <div class="d-flex justify-content-end pt-3 border-top">
                                        <a href="/pickinglist" class="btn btn-secondary btn-modern mr-3">
                                            <i class="fas fa-times mr-1"></i>Cancel
                                        </a>
                                        <button type="button"
                                                class="btn btn-primary btn-modern px-5"
                                                onclick="updateDO()">
                                            <i class="fas fa-save mr-2"></i>Update
                                        </button>
                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </section>

        </div>

        @Html.Partial("_Footer")

    </div>

    @Html.Partial("_BaseScript")
    
    <script src="~/helper/api.js"></script>
    <script src="~/helper/alert.js"></script>

    <script>

        const canUpdate = @canUpdate.ToString().ToLower();
        let id = "@ViewData["id"]";

        $(document).ready(load);

        async function load() {

            const data = await Api.get(`/api/pickinglist/${id}`);

            if (!data) {
                Alert.error("Failed to load data");
                return;
            }

            $("#doNumber").val(data.doNumber);

            $("#details").html("");

            data.details.forEach(d => {
                addDetail(d.itemId, d.qtyRequired);
            });
        }

        async function loadItemDropdown(selectedId = "") {

            const data = await Api.get("/api/item");
            if (!data) return;

            let options = `<option value="">-- Select Item --</option>`;

            data.forEach(item => {
                options += `<option value="${item.id}">${item.itemName}</option>`;
            });

            let lastSelect = $(".item-select").last();
            lastSelect.html(options);

            if (selectedId) {
                lastSelect.val(selectedId);
            }

            initSelect2();
        }

        function initSelect2(parent = document) {
            $(parent).find('.select2').select2({
                theme: 'bootstrap4',
                placeholder: "Search...",
                width: '100%',
                dropdownParent: $('body')
            });
        }

        $(document).on('select2:open', () => {
            document.querySelector('.select2-container--open .select2-search__field').focus();
        });

        $(document).on("click", ".remove-item", async function () {

            const confirm = await Alert.confirm({
                text: "Delete item?"
            });

            if (!confirm.isConfirmed) return;

            $(this).closest(".detail-item").remove();
        });

        function addDetail(selectedId = "", qty = "") {

            $("#details").append(`
                <div class="row mb-2 detail-item align-items-center">
                    <div class="col">
                        <select class="form-control select2 item-select"></select>
                    </div>
                    <div class="col">
                        <input class="form-control qty" value="${qty}" type="number">
                    </div>
                    <div class="col-2 text-center">
                        <button type="button" class="btn btn-danger btn-sm remove-item">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>
            `);

            loadItemDropdown(selectedId);
            initSelect2($("#details"));
        }

        async function updateDO() {

            if (!canUpdate) {
                Alert.error("You do not have permission to update");
                return;
            }

            let details = [];

            $("#details .detail-item").each(function () {
                const itemId = $(this).find(".item-select").val();
                const qty = parseInt($(this).find(".qty").val());

                if (!itemId || !qty || qty <= 0) return;

                details.push({
                    itemId,
                    qtyRequired: qty
                });
            });

            if (details.length === 0) {
                return Alert.error("Please add at least one item");
            }

            const payload = {
                doNumber: $("#doNumber").val(),
                details
            };

            const res = await Api.put(`/api/pickinglist/${id}`, payload);

            if (res && res.ok) {

                await Alert.success("Picking List updated successfully");
                window.location.href = "/pickinglist";

            } else {

                Alert.error("Update failed");

            }
        }

        $(document).keydown(function(e) {
            if (e.ctrlKey && e.key === 'Enter') updateDO();
            if (e.key === 'Escape') window.location.href = "/pickinglist";
        });

    </script>

</body>