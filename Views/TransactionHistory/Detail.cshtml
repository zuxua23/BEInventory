<body class="hold-transition layout-fixed layout-navbar-fixed">

    <div class="wrapper">

        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")
        @Html.Partial("Styles/_ViewsStyle")

        <div class="content-wrapper">

            <section class="content-header">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between flex-wrap mb-4">

                        <div class="d-flex align-items-center">
                            <div class="header-icon mr-3">
                                <i class="fas fa-history nav-icon text-primary"
                                   style="font-size: 2.25rem; opacity: 0.8;"></i>
                            </div>
                            <div>
                                <h1 class="h3 mb-1 text-dark font-weight-bold">Detail Transaction</h1>
                                <p class="mb-0 text-muted small">Transaction history detail information</p>
                            </div>
                        </div>

                        <nav class="modern-breadcrumb">
                            <ol class="breadcrumb bg-transparent p-0 mb-0">
                                <li class="breadcrumb-item">
                                    <a href="/dashboard" class="text-muted">
                                        <i class="fas fa-home mr-1"></i>Dashboard
                                    </a>
                                </li>
                                <li class="breadcrumb-item">
                                    <a href="/TransactionHistory" class="text-muted">
                                        <i class="fas fa-history mr-1"></i>Transaction History
                                    </a>
                                </li>
                                <li class="breadcrumb-item active">
                                    <i class="fas fa-info-circle mr-1"></i>Detail
                                </li>
                            </ol>
                        </nav>

                    </div>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">

                    <div class="card form-card shadow-lg p-2 p-sm-3 p-md-4 mb-4">
                        <div class="card-header">
                            <h3 class="card-title mb-0 font-weight-bold">
                                <i class="fas fa-info-circle mr-2 text-primary"></i>
                                Transaction Information
                            </h3>
                        </div>

                        <div class="card-body">
                            <div class="row">

                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>
                                            <i class="fas fa-calendar-alt text-muted mr-2"></i>
                                            Transaction Date
                                        </label>
                                        <input id="txDate" class="form-control" readonly>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>
                                            <i class="fas fa-exchange-alt text-muted mr-2"></i>
                                            Transaction Type
                                        </label>
                                        <input id="txType" class="form-control" readonly>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>
                                            <i class="fas fa-file-alt text-muted mr-2"></i>
                                            DO Number
                                        </label>
                                        <input id="doNumber" class="form-control" readonly>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>
                                            <i class="fas fa-broadcast-tower text-muted mr-2"></i>
                                            Reader Name
                                        </label>
                                        <input id="readerName" class="form-control" readonly>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group mb-0">
                                        <label>
                                            <i class="fas fa-tags text-muted mr-2"></i>
                                            Total Tag
                                        </label>
                                        <input id="totalTag" class="form-control" readonly>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>

                    <div class="card card-primary card-outline shadow-lg">
                        <div class="card-header bg-white border-0 pb-0">
                            <h3 class="card-title font-weight-bold mb-0">
                                <i class="fas fa-list mr-2 text-primary"></i>
                                Transaction Detail List
                            </h3>
                        </div>

                        <div class="card-body pt-3">
                            <div class="table-responsive">
                                <table id="datatablesDetail" class="table table-hover">
                                    <thead class="thead-light">
                                        <tr>
                                            <th class="text-center" width="60">#</th>
                                            <th>Tag ID</th>
                                            <th>Item Name</th>
                                            <th>Location</th>
                                        </tr>
                                    </thead>
                                </table>
                            </div>

                            <div class="d-flex justify-content-end pt-3 border-top">
                                <a href="/TransactionHistory" class="btn btn-secondary btn-modern action-btn">
                                    <i class="fas fa-arrow-left mr-1"></i>Back
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
            </section>

        </div>

        @Html.Partial("_Footer")

    </div>

    @Html.Partial("_BaseScript")

    <script src="~/helper/api.js"></script>
    <script src="~/helper/alert.js"></script>
    <script src="~/helper/table.js"></script>

    <script>
        let id = "@ViewData["id"]";
        let table;

        $(document).ready(function () {
            loadTransaction();
        });

        async function loadTransaction() {

            const data = await Api.get(`/api/transaction/${id}`);

            if (!data) {
                Alert.error("Failed to load transaction detail");
                return;
            }

            $("#txDate").val(
                data.txDate
                    ? new Date(data.txDate).toLocaleString("id-ID")
                    : "-"
            );

            $("#txType").val(data.txType || "-");
            $("#doNumber").val(data.doNumber || "-");
            $("#readerName").val(data.readerName || "-");
            $("#totalTag").val(data.totalTag || 0);

            table = Table.init("#datatablesDetail", {
                data: data.details || [],
                columns: [
                    Table.rowNumber(),
                    { data: "tagId", defaultContent: "-" },
                    { data: "itemName", defaultContent: "-" },
                    { data: "locationName", defaultContent: "-" }
                ],
            });
        }

        $(document).keydown(function (e) {
            if (e.key === 'Escape') {
                window.location.href = "/TransactionHistory";
            }
        });
    </script>

</body>