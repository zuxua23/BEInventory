<body class="hold-transition  layout-fixed">

    <div class="wrapper">

        @Html.Partial("_Navbar")
        @Html.Partial("_Sidebar")
        @Html.Partial("Styles/_ViewsStyle")

        <div class="content-wrapper">

            <section class="content-header">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between flex-wrap mb-4">

                        <div class="d-flex align-items-center">
                            <div class="header-icon mr-3">
                                <i class="fas fa-print nav-icon text-primary"
                                   style="font-size: 2.25rem; opacity: 0.8;"></i>
                            </div>
                            <div>
                                <h1 class="h3 mb-1 text-dark font-weight-bold">Print Tag</h1>
                                <p class="mb-0 text-muted small">Manage tag printing process</p>
                            </div>
                        </div>

                        <nav aria-label="breadcrumb" class="modern-breadcrumb">
                            <ol class="breadcrumb bg-transparent p-0 mb-0">
                                <li class="breadcrumb-item">
                                    <a href="/dashboard" class="text-muted">
                                        <i class="fas fa-home mr-1"></i>Dashboard
                                    </a>
                                </li>
                                <li class="breadcrumb-item active">
                                    <i class="fas fa-clipboard-list mr-1"></i>Print Tag
                                </li>
                            </ol>
                        </nav>

                    </div>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid">
                    <div class="row mb-4">
                        <div class="col-md-8">
                            <div class="card card-primary card-outline shadow-lg h-100">
            
                                <div class="card-header bg-white border-0 pb-0">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h3 class="card-title font-weight-bold mb-0">
                                            <i class="fas fa-list mr-2 text-primary"></i>
                                            Item List
                                        </h3>
                                    </div>
                                </div>

                                <div class="card-body pt-3">
                                    <table class="table table-bordered table-hover" id="tagTable">
                                        <thead class="thead-light">
                                            <tr>
                                                <th width="60">#</th>
                                                <th>Item</th>
                                                <th width="120">Qty</th>
                                                <th width="100">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td>1</td>
                                                <td>
                                                    <select class="form-control select2 item-select" data-row="1" id="firstItemSelect"></select>
                                                </td>
                                                <td>
                                                    <input type="number" class="form-control qty-input" min="1" max="100" value="1">
                                                </td>
                                                <td>
                                                    <button class="btn btn-sm btn-danger" onclick="removeRow(this)">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>

                                    <button class="btn btn-primary mt-3" onclick="addRow()">
                                        <i class="fas fa-plus"></i> Add Row
                                    </button>
                                </div>
            
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card shadow-lg">
                                <div class="card-header bg-success text-white">
                                    <h3 class="card-title font-weight-bold mb-0">
                                        <i class="fas fa-print mr-2"></i>Print
                                    </h3>
                                </div>
                                <div class="card-body d-flex flex-column">

                                    <div class="form-group text-center">
                                        <label class="font-weight-bold text-muted" style="font-size: 1.75rem;">Total Tags</label>

                                        <div id="totalTags"
                                             class="badge badge-primary badge-lg d-block p-3 text-center"
                                             style="font-size: 1.5rem;">
                                            0
                                        </div>
                                    </div>

                                    <button id="btnPrintTags" class="btn btn-primary btn-block mb-2" style="font-size: 1.5rem;" onclick="printTags()">
                                        <i class="fas fa-print mr-2"></i> Print Tag
                                    </button>

                                    <button type="button" class="btn btn-info btn-block mb-2" style="font-size: 1.5rem;" onclick="openPrinterSettingModal()">
                                        <i class="fas fa-cog mr-2"></i> Printer Setting
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">

                            <div class="card card-primary card-outline shadow-lg">

                                <div class="card-header bg-white border-0 pb-0">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h3 class="card-title font-weight-bold mb-0">
                                            <i class="fas fa-list mr-2 text-primary"></i>
                                            Tag Data List
                                        </h3>
                                    </div>
                                </div>

                                <div class="card-body pt-3">

                                    <div class="table-responsive">
                                        <table id="datatablesIndex" class="table table-hover">
                                            <thead class="thead-light">
                                                <tr>
                                                    <th class="text-center" width="60">#</th>
                                                    <th>Tag ID</th>
                                                    <th>Item Name</th>
                                                    <th>Epc</th>
                                                    <th>Location</th>
                                                    <th>Status</th>
                                                </tr>
                                            </thead>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
               </div>
            </section>                
        </div>
        @Html.Partial("_Footer")

    </div>

    <div class="modal fade" id="printerSettingModal" tabindex="-1" role="dialog" aria-labelledby="printerSettingModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-md" role="document">
            <div class="modal-content">

                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="printerSettingModalLabel">
                        <i class="fas fa-print mr-2"></i>
                        Printer Setting
                    </h5>

                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>

                <div class="modal-body">
                    <div class="form-group">
                        <label class="font-weight-bold">Printer Name</label>
                        <input type="text"
                               class="form-control"
                               id="printerNameInput"
                               placeholder="Example: SATO CL4NX 305dpi">

                        <small class="form-text text-muted">
                            Make sure the printer name matches the printer name in Windows.
                        </small>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-secondary"
                            data-dismiss="modal">
                        Cancel
                    </button>

                    <button type="button"
                            class="btn btn-primary"
                            id="btnSavePrinterSetting"
                            onclick="savePrinterSetting()">
                        <i class="fas fa-save mr-1"></i>
                        Save
                    </button>
                </div>

            </div>
        </div>
    </div>
  
    @Html.Partial("_BaseScript")
    
    <script src="~/helper/api.js"></script>
    <script src="~/helper/alert.js"></script>
    <script src="~/helper/table.js"></script>
    <script>

        let table;
        let rowCounter = 1;
        let itemsCache = [];


        $(document).ready(async function () {

            await initializePage();

        });



        async function initializePage() {

            await loadItems();
            initializeFirstDropdown();
            await loadTagTable();
            initializeEvents();
            updateTotalTags();
        }




        function initializeFirstDropdown() {

            const firstDropdown =
                document.getElementById(
                    "firstItemSelect"
                );

            renderDropdownOptions(
                firstDropdown
            );

            initSelect2();
        }




        function initializeEvents() {

            $(document).on(
                "click",
                ".btn-remove-row",
                async function () {

                    const confirm =
                        await Alert.confirm({
                            text: "Delete row?"
                        });

                    if (!confirm.isConfirmed)
                        return;

                    $(this)
                        .closest("tr")
                        .remove();

                    updateRowNumbers();

                    updateTotalTags();
                }
            );

            $(document).on(
                "input",
                ".qty-input",
                function () {

                    updateTotalTags();

                }
            );

            $(document).on(
                "select2:open",
                function () {

                    document
                        .querySelector(
                            '.select2-container--open .select2-search__field'
                        )
                        ?.focus();

                }
            );
        }




        async function loadItems() {

            const data = await Api.get("/api/item");

            if (!data) {

                Alert.error("Failed to load items");

                return;
            }

            itemsCache = data;
        }

        function renderDropdownOptions(
            selectElement
        ) {

            let options =
                `<option value="">
                    -- Select Item --
                </option>`;

            itemsCache.forEach(item => {

                options += `
                    <option value="${item.id}">
                        ${item.itemName}
                    </option>
                `;
            });

            selectElement.innerHTML =
                options;
        }



        async function loadTagTable() {

            const data = await Api.get("/api/tag");

            if (!data) return;

            if (table) {

                table.clear();

                table.rows
                    .add(data)
                    .draw();

                return;
            }

            table = Table.init(
                "#datatablesIndex",
                {
                    data: data,
                    columns: [
                        Table.rowNumber(),
                        {
                            data: "tagId",
                            render: d =>
                                `<code>${d}</code>`
                        },
                        {
                            data: "itemName"
                        },
                        {
                            data: "epc"
                        },
                        {
                            data: "location"
                        },

                        {
                            data: "status",
                            render: renderStatusBadge
                        }
                    ]
                }
            );
        }




        function renderStatusBadge(status) 
        {

            const badgeMap = {

                PRINTED:
                    "badge-primary",

                STANDBY:
                    "badge-warning",

                OUT:
                    "badge-danger",

                IN_STOCK:
                    "badge-success"
            };

            return `
                <span class="badge ${badgeMap[status] || 'badge-secondary'}">
                    ${status || "-"}
                </span>
            `;
        }



        function addRow() {

            rowCounter++;

            const tbody = document.querySelector(
                    "#tagTable tbody"
                );

            const row = document.createElement("tr");

            row.innerHTML =
                generateRowTemplate(
                    rowCounter
                );

            tbody.appendChild(row);

            const dropdown = row.querySelector(
                    ".item-select"
                );

            renderDropdownOptions(
                dropdown
            );

            initSelect2(row);

            updateTotalTags();
        }



        function generateRowTemplate(
            rowNumber
        ) {
            return `
                <td>${rowNumber}</td>

                <td>
                    <select class="form-control select2 item-select"></select>
                </td>

                <td>
                    <input
                        type="number"
                        class="form-control qty-input"
                        min="1"
                        max="1000"
                        value="1"
                    >
                </td>

                <td>
                    <button
                        type="button"
                        class="btn btn-sm btn-danger btn-remove-row"
                    >
                        <i class="fas fa-trash"></i>
                    </button>
                </td>
            `;
        }



        function updateRowNumbers() {

            const rows = document.querySelectorAll(
                    "#tagTable tbody tr"
                );

            rows.forEach((row, index) => {

                row.cells[0].textContent =
                    index + 1;
            });

            rowCounter = rows.length;
        }



        function updateTotalTags() {

            let total = 0;

            document.querySelectorAll(".qty-input"  )
                .forEach(input => {

                    total += parseInt(input.value) || 0;

                });

            document.getElementById("totalTags" ).textContent = total.toLocaleString();
        }



        function initSelect2(
            parent = document
        ) {

            $(parent)
                .find(".select2")
                .select2({

                    theme: "bootstrap4",

                    placeholder:
                        "Search item...",

                    width: "100%",

                    dropdownParent:
                        $("body")
                });
        }




        async function printTags() {

            const button =  document.getElementById("btnPrintTags");

            try
            {
                setButtonLoading(
                    button,
                    true
                );

                const payload = buildPrintPayload();

                if (!payload)
                    return;

                showPrintLoading();

                const res =
                    await Api.post(
                        "/api/tag/print",
                        payload
                    );

                Swal.close();

                if (!res || !res.ok)
                {
                    if (
                        res?.errorData?.type ===
                        "warning"
                    ) {
                        return;
                    }

                    Alert.error("Failed to print tags");

                    return;
                }

                await Alert.success(
                    "Tags printed successfully"
                );

                resetForm();

                await loadTagTable();
            }
            catch (err)
            {
                Swal.close();

                Alert.error(
                    err.message ||
                    "Failed to print tags"
                );
            }
            finally
            {
                setButtonLoading(
                    button,
                    false
                );
            }
        }



        function buildPrintPayload() {

            const rows = document.querySelectorAll(
                    "#tagTable tbody tr"
                );

            const payload = [];

            for (const row of rows)
            {
                const itemId = row.querySelector(".item-select" ).value;

                const qty = parseInt(
                        row.querySelector( ".qty-input" ).value
                    );

                if (!itemId)
                {
                    Alert.error( "Please select item in all rows" );

                    return null;
                }

                if (qty <= 0)
                {
                    Alert.error( "Quantity must be greater than zero" );

                    return null;
                }

                payload.push({
                    itemId,
                    qty
                });
            }

            if (payload.length === 0)
            {
                Alert.error( "Please add at least one item" );

                return null;
            }

            return payload;
        }



        function showPrintLoading() {

            Swal.fire({
                title: "Printing...",
                allowOutsideClick: false,
                didOpen: () =>
                    Swal.showLoading()
            });
        }



        function setButtonLoading(
            button,
            isLoading
        ) {

            button.disabled =
                isLoading;
        }



        function resetForm() {

            const tbody = document.querySelector(
                    "#tagTable tbody"
                );

            const row = document.createElement("tr");

            row.innerHTML = generateRowTemplate(1);
            tbody.innerHTML = "";
            tbody.appendChild(row);
            rowCounter = 1;

            const dropdown = row.querySelector(
                    ".item-select"
            );

            renderDropdownOptions(
                dropdown
            );

            initSelect2();
            updateTotalTags();
        }

        async function openPrinterSettingModal() {
            try {
                const input = document.getElementById("printerNameInput");

                input.value = "";

                const data = await Api.get("/printer");

                if (data && data.printerName) {
                    input.value = data.printerName;
                }

                $("#printerSettingModal").modal("show");
            }
            catch (err) {
                Alert.error(
                    err.message ||
                    "Failed to load printer setting"
                );
            }
        }



        async function savePrinterSetting() {
            const button =
                document.getElementById("btnSavePrinterSetting");

            const printerName =
                document.getElementById("printerNameInput")
                    .value
                    .trim();

            if (!printerName) {
                Alert.error("Printer name cannot be empty");
                return;
            }

            try {
                setButtonLoading(button, true);

                const res = await Api.put(
                    "/printer",
                    {
                        printerName: printerName
                    }
                );

                if (!res || !res.ok) {
                    Alert.error("Failed to update printer setting");
                    return;
                }

                $("#printerSettingModal").modal("hide");

                await Alert.success(
                    "Printer setting updated successfully"
                );
            }
            catch (err) {
                Alert.error(
                    err.message ||
                    "Failed to update printer setting"
                );
            }
            finally {
                setButtonLoading(button, false);
            }
        }

    </script>

</body>